# 클라이언트 API URL (모바일/웹 빌드용)
VITE_API_BASE_URL=https://ppamong.com

# AdMob (앱 빌드 시 VITE_* 설정 또는 관리자에서 광고 단위 선택 → /api/config/admob)
# VITE_ADMOB_AD_ID_ANDROID=ca-app-pub-xxxxxxxx/yyyyyyyy
# VITE_ADMOB_AD_ID_IOS=ca-app-pub-xxxxxxxx/yyyyyyyy

# AdMob 수익 리포트 API (관리자 → 동영상 광고 수익 현황, 서버 전용)
# ADMOB_CLIENT_ID=xxxx.apps.googleusercontent.com
# ADMOB_CLIENT_SECRET=GOCSPX-xxxx
# ADMOB_PUBLISHER_ID=pub-xxxxxxxxxxxxxxxx
# ADMOB_REFRESH_TOKEN=1//xxxx

# 서버
BASE_URL=https://ppamong.com
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ppamong?retryWrites=true&w=majority
MONGODB_DB_NAME=ppamong

# 레거시 PostgreSQL (선택) — 빠던9 공유 DB → MongoDB 가져오기
# 방법 A (빠던9 Replit과 동일, 권장):
# PGHOST=ep-xxxx.aws.neon.tech
# PGPORT=5432
# PGUSER=neondb_owner
# PGPASSWORD=비밀번호
# PGDATABASE=ppadun9
# 방법 B: DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# PG_DATABASE_NAME=ppadun9  # DATABASE_URL 경로 DB만 바꿀 때
# PG_MONGO_SYNC_ENABLED=true       # 기본 false — 레거시 PostgreSQL 자동 가져오기(선택)
# PG_MONGO_SYNC_MODE=replace       # replace=테이블 비우고 재저장(백필) | merge=upsert(기본)
# PG_MONGO_SYNC_HOUR_KST=1         # 자동 동기화 시각(한국시간, 기본 01:00)
# PG_MONGO_SYNC_MINUTE_KST=0

# JWT
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# Redis (Replit 내장: HOST/PORT 생략 가능. Upstash 등 외부 사용 시)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# OAuth (Kakao / Google / Apple)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
