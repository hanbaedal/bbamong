# 클라이언트 API URL (모바일/웹 빌드용)
VITE_API_BASE_URL=https://ppamong.com

# AdMob (앱 빌드 시 npm run build 전에 설정 — Vite는 빌드 시점에 주입)
# VITE_ADMOB_AD_ID_ANDROID=ca-app-pub-xxxxxxxx/yyyyyyyy
# VITE_ADMOB_AD_ID_IOS=ca-app-pub-xxxxxxxx/yyyyyyyy

# 서버
BASE_URL=https://ppamong.com
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ppamong?retryWrites=true&w=majority
MONGODB_DB_NAME=ppamong

# 레거시 PostgreSQL (선택) — 슈퍼바이저 DB 백업·PostgreSQL→MongoDB 동기화용
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# PG_MONGO_SYNC_ENABLED=true  # 기본 false — 레거시 PostgreSQL 자동 가져오기(선택)
# PG_MONGO_SYNC_INTERVAL_MS=1800000

# JWT
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# Redis (Replit 내장: HOST/PORT 생략 가능. Upstash 등 외부 사용 시)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# OAuth (Kakao / Google / Apple)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
